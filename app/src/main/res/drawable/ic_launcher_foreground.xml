<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Glowing rays (Orange/Yellow) on the right side -->
    <path
        android:strokeColor="#FF9F1C"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:pathData="M 75,44 L 81,40" />
    <path
        android:strokeColor="#FF9F1C"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:pathData="M 78,54 L 85,54" />
    <path
        android:strokeColor="#FF9F1C"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:pathData="M 75,64 L 81,68" />

    <!-- Lightbulb Central Circle (Glowing orange-yellow gradient) -->
    <path
        android:pathData="M 54,54 m -13,0 a 13,13 0 1,1 26,0 a 13,13 0 1,1 -26,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="41"
                android:startY="41"
                android:endX="67"
                android:endY="67">
                <item android:offset="0.0" android:color="#FFE066" />
                <item android:offset="1.0" android:color="#FF5E3A" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Lightbulb / Pencil Bulb Outline & Stem (Beautiful blue-violet-pink gradient) -->
    <!-- This path traces the lightbulb outline, the neck, and down to the pencil tip -->
    <path
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 45,64 C 41,64 36,60 36,53 C 36,43 44,36 54,36 C 64,36 72,43 72,53 C 72,60 67,64 63,64 L 63,68 L 45,68 Z">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="36"
                android:startY="36"
                android:endX="72"
                android:endY="68">
                <item android:offset="0.0" android:color="#00A8CC" />
                <item android:offset="0.5" android:color="#803BEC" />
                <item android:offset="1.0" android:color="#D62196" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Pencil Neck Ridges (Horizontal purple lines) -->
    <path
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M 47,72 L 61,72" />
    <path
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M 47,76 L 61,76" />
    <aapt:attr name="android:strokeColor">
        <gradient
            android:type="linear"
            android:startX="47"
            android:startY="72"
            android:endX="61"
            android:endY="76">
            <item android:offset="0.0" android:color="#803BEC" />
            <item android:offset="1.0" android:color="#D62196" />
        </gradient>
    </aapt:attr>

    <!-- Pencil tip triangle (pointing down) -->
    <path
        android:fillColor="#D62196"
        android:pathData="M 47,80 L 61,80 L 54,92 Z" />

    <!-- Pencil tip lead core (dark pink/black) -->
    <path
        android:fillColor="#1E1B4B"
        android:pathData="M 51,85 L 57,85 L 54,92 Z" />

    <!-- Graduation Cap (Diamond Top, tilted elegantly at the top left) -->
    <path
        android:pathData="M 48,22 L 72,30 L 48,38 L 24,30 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="24"
                android:startY="22"
                android:endX="72"
                android:endY="38">
                <item android:offset="0.0" android:color="#2C2E43" />
                <item android:offset="1.0" android:color="#1F1D36" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Graduation Cap Under-base -->
    <path
        android:pathData="M 33,31.5 L 33,36 C 33,40 50,42 50,36 L 50,33">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="33"
                android:startY="31.5"
                android:endX="50"
                android:endY="36">
                <item android:offset="0.0" android:color="#1F1D36" />
                <item android:offset="1.0" android:color="#12101F" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Graduation Cap Tassel -->
    <path
        android:strokeColor="#D62196"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M 28,31 L 28,42" />
    <path
        android:fillColor="#D62196"
        android:pathData="M 26,42 L 30,42 L 28,47 Z" />

</vector>
